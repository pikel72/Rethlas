# Copy this file to .env and fill in the values you need.
# PowerShell users can load values manually with:
#   $env:OPENAI_API_KEY = "..."
#   $env:ANTHROPIC_API_KEY = "..."
#
# Bash/zsh users can load the file with:
#   set -a
#   source .env
#   set +a

# OpenAI / OpenAI-compatible models through LiteLLM.
OPENAI_API_KEY=

# Anthropic models through LiteLLM.
ANTHROPIC_API_KEY=

# Optional: choose a default model profile for this shell session.
# This overrides [runtime].default_model in rethlas.toml.
# Examples: gpt-5.5, codex-fast, openai-fast, openai-deep,
# anthropic-fast, anthropic-deep, mock-generation.
RETHLAS_MODEL=

# Optional: Codex CLI binary name or path if it is not simply "codex".
CODEX_BIN=codex

# Optional: used by some LiteLLM/provider setups.
OPENAI_API_BASE=
ANTHROPIC_API_BASE=
