# =============================================================================
# Rethlas AI 模型预设
# =============================================================================
#
# 用法:
#   1. cp .env.example .env
#   2. 在 .env 里填 key, 改想用的厂商/模型
#   3. python -m rethlas.cli run <problem>
#
# 设计原则:
#   - 每个内置预设只携带厂商元数据 (base_url / 协议 / key env), 不携带默认模型名
#   - 真实模型名 100% 由 <KEY>_MODEL 决定, 厂商发新模型只需改一行 .env, 无需 Rethlas 发版
#   - 每个厂商下面列几个示例模型名; 实际可用模型以厂商文档/控制台为准
#   - RETHLAS_MODEL 选预设; 不设则用 rethlas.toml 的 [runtime].default_model (默认 gpt-5.5 / codex)
#
# 详细规范: docs/superpowers/specs/2026-06-07-env-model-presets-design.md


# =============================================================================
# --- DeepSeek ---  协议: openai-compatible
# =============================================================================
# 官网:       https://platform.deepseek.com
# 文档:       https://api-docs.deepseek.com/
# key 申请:   https://platform.deepseek.com/api_keys
# 示例模型 (填到 DEEPSEEK_MODEL; 请按厂商文档替换为实际可用 ID):
#   deepseek-v4-pro
#   deepseek-v4-flash
#   deepseek-chat
#   deepseek-reasoner
# 代理/自部署: DEEPSEEK_API_BASE=https://...
DEEPSEEK_API_KEY=
DEEPSEEK_API_BASE=
DEEPSEEK_MODEL=deepseek-v4-pro


# =============================================================================
# --- OpenAI ---  协议: openai-compatible
# =============================================================================
# 官网:       https://openai.com
# 文档:       https://platform.openai.com/docs
# key 申请:   https://platform.openai.com/api-keys
# 示例模型:
#   gpt-5.5
#   gpt-5.5-pro
#   gpt-5.4-mini
#   gpt-5.3-chat
# 代理/自部署: OPENAI_API_BASE=https://...
OPENAI_API_KEY=
OPENAI_API_BASE=
OPENAI_MODEL=gpt-5.5


# =============================================================================
# --- Anthropic Claude ---  协议: anthropic-compatible
# =============================================================================
# 官网:       https://www.anthropic.com
# 文档:       https://docs.anthropic.com
# key 申请:   https://console.anthropic.com/settings/keys
# 示例模型:
#   claude-opus-4.8
#   claude-opus-4.8-fast
#   claude-opus-4.7
#   claude-sonnet-latest
#   claude-haiku-latest
ANTHROPIC_API_KEY=
ANTHROPIC_API_BASE=
CLAUDE_MODEL=claude-opus-4.8


# =============================================================================
# --- Google Gemini ---  协议: openai-compatible (走 Google 的 OpenAI 兼容端点)
# =============================================================================
# 官网:       https://ai.google.dev
# 文档:       https://ai.google.dev/gemini-api/docs
# key 申请:   https://aistudio.google.com/apikey
# 示例模型:
#   gemini-3.5-flash
#   gemini-3.1-flash-lite
#   gemma-4-31b-it
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-3.5-flash


# =============================================================================
# --- 通义千问 (阿里 DashScope) ---  协议: openai-compatible
# =============================================================================
# 官网:       https://qwen.ai
# 文档:       https://help.aliyun.com/zh/model-studio
# key 申请:   https://dashscope.console.aliyun.com/apiKey
# 示例模型:
#   qwen3.7-max
#   qwen3.7-plus
#   qwen3.6-flash
QWEN_API_KEY=
QWEN_MODEL=qwen3.7-plus


# =============================================================================
# --- Moonshot Kimi ---  协议: openai-compatible
# =============================================================================
# 官网:       https://kimi.moonshot.cn
# 文档:       https://platform.moonshot.cn/docs
# key 申请:   https://platform.moonshot.cn/user-center/api-keys
# 示例模型:
#   kimi-k2.6
#   kimi-latest
KIMI_API_KEY=
KIMI_API_BASE=
KIMI_MODEL=kimi-k2.6


# =============================================================================
# --- OpenRouter ---  协议: openai-compatible (聚合多家模型)
# =============================================================================
# 官网:       https://openrouter.ai
# 文档:       https://openrouter.ai/docs
# key 申请:   https://openrouter.ai/settings/keys
# 示例模型 (实际可用任何路由模型, 写 vendor/model 形式):
#   anthropic/claude-opus-4.8
#   openai/gpt-5.5
#   google/gemini-3.5-flash
#   deepseek/deepseek-v4-pro
#   qwen/qwen3.7-max
#   moonshotai/kimi-k2.6
#   xiaomi/mimo-v2.5-pro
#   z-ai/glm-5.1
# 完整模型列表: https://openrouter.ai/models
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-opus-4.8


# =============================================================================
# --- Ollama (本地) ---  协议: openai-compatible
# =============================================================================
# 官网:       https://ollama.com
# 文档:       https://github.com/ollama/ollama/blob/main/docs/api.md
# 安装:       https://ollama.com/download
# 示例模型 (任何 ollama pull 下来的都行):
#   llama3.3
#   qwen3                  (本地版 Qwen3, 大小可选)
#   deepseek-r1
#   gemma3
# 注: 本地服务, key 可空 (但 OLLAMA_API_KEY 这行建议留空, 系统会跳过 key 检查)
OLLAMA_API_KEY=
OLLAMA_MODEL=llama3.3


# =============================================================================
# --- 智谱 GLM ---  协议: openai-compatible
# =============================================================================
# 官网:       https://www.zhipuai.cn
# 文档:       https://docs.bigmodel.cn
# key 申请:   https://bigmodel.cn/user-center/apikeys
# 示例模型:
#   glm-5.1
#   glm-5-turbo
#   glm-5v-turbo
GLM_API_KEY=
GLM_MODEL=glm-5.1


# =============================================================================
# --- MiniMax ---  协议: openai-compatible
# =============================================================================
# 官网:       https://minimax.io
# 文档:       https://platform.minimax.io/docs
# key 申请:   https://platform.minimax.io/user-center/basic-information/interface-key
# 示例模型 (不同平台命名可能不同):
#   MiniMax-M3
#   MiniMax-M2.7
#   MiniMax-text-01
MINIMAX_API_KEY=
MINIMAX_API_BASE=
MINIMAX_MODEL=MiniMax-M3


# =============================================================================
# --- 硅基流动 (SiliconFlow) ---  协议: openai-compatible (聚合多家开源模型)
# =============================================================================
# 官网:       https://siliconflow.cn
# 文档:       https://docs.siliconflow.cn
# key 申请:   https://cloud.siliconflow.cn/account/ak
# 示例模型 (写 org/model 形式, Pro/ 前缀通常代表平台增强/付费能力):
#   Pro/zai-org/GLM-5             智谱旗舰
#   Pro/deepseek-ai/DeepSeek-V3.2 DeepSeek 上一代旗舰 (V4 还没上 SF)
#   Qwen/Qwen3.5-397B-A17B        阿里 MoE 旗舰
#   Qwen/Qwen3-30B-A3B            阿里 MoE 轻量
# 完整模型列表: https://docs.siliconflow.cn/cn/api-reference
SILICONFLOW_API_KEY=
SILICONFLOW_MODEL=Pro/zai-org/GLM-5


# =============================================================================
# --- 豆包 (火山方舟) ---  协议: openai-compatible
# =============================================================================
# 官网:       https://www.volcengine.com/product/doubao
# 文档:       https://www.volcengine.com/docs/82379
# key 申请:   https://console.volcengine.com/iam/apikeys
# 示例模型 (model 字段值, 不是 ep-xxx 端点 ID):
#   doubao-seed-1-6-250615
#   doubao-1-5-pro-32k
#   doubao-seed-2-0-lite
# 注: 也可以用控制台创建的 ep-xxxxxxxxxxxx 端点 ID
DOUBAO_API_KEY=
DOUBAO_API_BASE=
DOUBAO_MODEL=doubao-seed-1-6-250615


# =============================================================================
# --- 小米 MiMo ---  协议: openai-compatible
# =============================================================================
# 官网:       https://xiaomi.github.io/MiMo
# 文档:       https://github.com/XiaomiMiMo/MiMo
# key 申请:   小米开放平台 (需查最新入口)
# 示例模型:
#   mimo-v2.5-pro
#   mimo-v2.5
MIMO_API_KEY=
MIMO_API_BASE=
MIMO_MODEL=mimo-v2.5-pro


# =============================================================================
# --- Custom (任意未列出的厂商) ---
# =============================================================================
# 必填项 (无默认):
#   CUSTOM_API_BASE      任意 base URL, 如 https://my-proxy.example.com/v1
#   CUSTOM_COMPAT        openai 或 anthropic (决定 LiteLLM 协议路由)
#   CUSTOM_MODEL         真实模型名
# 可选:
#   CUSTOM_API_KEY       API key; 无鉴权本地代理可留空
#
# 例: 把上述任意厂商换成自家代理, 改 base URL + compat 即可
# CUSTOM_API_KEY=sk-...
# CUSTOM_API_BASE=https://my-proxy.example.com/v1
# CUSTOM_COMPAT=openai
# CUSTOM_MODEL=llama-3.3-70b
CUSTOM_API_KEY=
CUSTOM_API_BASE=
CUSTOM_COMPAT=
CUSTOM_MODEL=


# =============================================================================
# 全局选择
# =============================================================================

# 当前选用的预设 (不设则用 rethlas.toml 的 [runtime].default_model = "gpt-5.5" 即 codex)
# 可选: codex, gpt-5.5, codex-fast, codex-deep, mock-* (toml 段)
#       或任意上面 14 个 env 预设名
RETHLAS_MODEL=

# 可选: verification agent 单独指定 (不设则与 RETHLAS_MODEL 相同)
# 推荐: 用一个更便宜/更快的模型做 verification
# 例: RETHLAS_MODEL=claude, RETHLAS_VERIFICATION_MODEL=claude-haiku-latest
RETHLAS_VERIFICATION_MODEL=


# =============================================================================
# 非 preset 相关 (Codex CLI / misc)
# =============================================================================

# Codex CLI 二进制名 (默认 codex, 自定义安装时改)
CODEX_BIN=codex
